{
  "id": "everstory_save",
  "name": "everstory_save",
  "version": "1.0.0",
  "main": "index.html",
  "host": {
    "app": "PS",
    "minVersion": "27.5.0"
  },
  "manifestVersion": 5,
  "entrypoints": [
    {
      "type": "panel",
      "id": "save",
      "minimumSize": { "width": 240, "height": 240 },
      "maximumSize": { "width": 2000, "height": 2000 },
      "preferredDockedSize": { "width": 280, "height": 320 },
      "preferredFloatingSize": { "width": 320, "height": 360 },
      "label": { "default": "Everstory Save" }
    }
  ],
  "icons": [
    {
      "width": 23,
      "height": 23,
      "path": "icons/dark.png",
      "scale": [1, 2],
      "theme": ["darkest", "dark", "medium"]
    },
    {
      "width": 23,
      "height": 23,
      "path": "icons/light.png",
      "scale": [1, 2],
      "theme": ["lightest", "light"]
    }
  ],
  "requiredPermissions": {
    "localFileSystem": "fullAccess"
  }
}
